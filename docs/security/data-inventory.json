      "pii_classification": "low-sensitivity-usage-metadata",
      "consent_basis": "local-only",
      "retention_days": 30,
      "redaction_applied": true,
      "retention_policy_id": "resource-accounting-30d",
      "governance_class_ref": "vetinari/memory/governance/lifecycle.py::RetentionClass.EPHEMERAL"
    },
    {
      "store_id": "workbench_network_evidence",
      "file_path": "workbench network state JSON artifacts",
      "data_categories": ["network_observation", "provider_health", "routing_decision", "approval_packet"],
      "pii_classification": "low-sensitivity-usage-metadata",
      "consent_basis": "local-only",
      "retention_days": 30,
      "redaction_applied": true,
      "retention_policy_id": "network-evidence-30d",
      "governance_class_ref": "vetinari/memory/governance/lifecycle.py::RetentionClass.EPHEMERAL"
    },
