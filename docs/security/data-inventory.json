      "pii_classification": "high-sensitivity-user-content",
      "consent_basis": "explicit-opt-in",
      "retention_days": 0,
      "redaction_applied": true,
      "retention_policy_id": "cloud-provider-operator-owned",
      "governance_class_ref": "vetinari/memory/governance/lifecycle.py::RetentionClass.EPHEMERAL"
    },
