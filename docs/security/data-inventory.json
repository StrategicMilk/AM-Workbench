      "file_path": "outputs/models/capability.jsonl",
      "data_categories": ["model_id", "task_profile", "evidence_basis", "score", "redacted_issues", "redacted_suggestions", "tool_evidence_hashes", "provenance_metadata"],
      "pii_classification": "low-sensitivity-usage-metadata",
      "consent_basis": "local-only",
      "retention_days": 30,
      "redaction_applied": true,
