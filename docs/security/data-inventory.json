    }
  ],
  "retention_policies": [
    {
      "retention_policy_id": "training-records-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "TrainingDataCollector.purge_expired_records(cutoff_days=30) removes stale JSONL rows at startup; TrainingDataCollector.delete_records_for_subject() removes subject-matching training rows and trace artifacts; raw prompt/response are redacted before write and exports derive from the redacted records"
    },
    {
      "retention_policy_id": "observability-checkpoints-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "Pipeline checkpoint snapshots store redacted stage payloads and privacy receipts only; checkpoint cleanup follows the ephemeral observability retention class and removes stale snapshot rows before they can be reused as training or export data"
    },
    {
      "retention_policy_id": "memory-active-plus-tombstone",
      "maximum_retention_days": 365,
      "deletion_mechanism": "forget() tombstones records and overwrites content with [forgotten]; compact_memories() physically removes tombstoned rows"
    },
    {
      "retention_policy_id": "logs-14d",
      "maximum_retention_days": 14,
      "deletion_mechanism": "bounded SSE buffer plus operator log rotation; LogRecord serialization redacts PII before file/SSE emission"
    },
    {
      "retention_policy_id": "external-log-shipping-operator-owned",
      "maximum_retention_days": 0,
      "deletion_mechanism": "DatadogBackend and WebhookBackend are explicit opt-in transports; LogRecord serialization redacts payloads before network send and remote retention is governed by the operator-configured external system"
    },
    {
      "retention_policy_id": "support-bundles-operator-owned",
      "maximum_retention_days": 0,
      "deletion_mechanism": "operator-owned export artifact; builder redacts UTF-8 content before writing bundle"
    },
    {
      "retention_policy_id": "outputs-scratch-14d",
      "maximum_retention_days": 14,
      "deletion_mechanism": "TrainingScheduler idle maintenance sweeps stale outputs/ scratch artifacts"
    },
    {
      "retention_policy_id": "rag-debugger-experiments-14d",
      "maximum_retention_days": 14,
      "deletion_mechanism": "RAG debugger experiments are local-only diagnostic JSONL under outputs/workbench/rag_debugger; resource JSONL rotation redacts raw prompts and payload secrets before append; operator output cleanup removes stale experiment logs and experiments are not reused for training unless exported through an explicit eval workflow"
    },
    {
      "retention_policy_id": "rag-knowledge-base-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "KnowledgeBase document rows carry vetinari-privacy-envelope.v1 receipts with erasure tokens; retrieval fails closed when a row lacks a valid receipt, and local database cleanup owns stale document removal."
    },
    {
      "retention_policy_id": "resource-accounting-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "Resource accounting state stores only project, lease, model, token, GPU-hour, and cost metadata. JSONL ledgers rotate before configured byte/line budgets are exceeded, lease registry writes use atomic replace, subject deletion follows project-output cleanup, and records are not reused for training or evals unless exported through an explicit operator workflow."
    },
    {
      "retention_policy_id": "network-evidence-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "NetworkTransportStateStore writes only redacted evidence; operator state cleanup removes stale JSON artifacts"
    },
    {
      "retention_policy_id": "cloud-provider-operator-owned",
      "maximum_retention_days": 0,
      "deletion_mechanism": "Cloud providers are explicit opt-in inference transports; local request records are governed by the local training/trace policies and provider-side deletion follows the operator-configured provider account"
    },
    {
      "retention_policy_id": "trace-exports-14d",
      "maximum_retention_days": 14,
      "deletion_mechanism": "GenAI exporter redacts tool payloads at record/export time; trace export files are operator-managed"
    },
    {
      "retention_policy_id": "chat-exports-operator-owned",
      "maximum_retention_days": 0,
      "deletion_mechanism": "operator-requested response artifact; export and attachment paths redact content before response bytes leave the app"
    },
    {
      "retention_policy_id": "feedback-signals-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "FeedbackLoop retention uses local-only redacted signals and periodic store pruning before reuse in adaptive tuning"
    },
    {
      "retention_policy_id": "model-performance-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "SubtaskMemory.prune_old_plans and plan retention receipts bound model-performance rows used for plan quality adaptation"
    },
    {
      "retention_policy_id": "capability-maturity-30d",
      "maximum_retention_days": 30,
      "deletion_mechanism": "append_capability_record persists minimized OutcomeSignal evidence only: tool stdout is replaced by a hash, commands/issues/suggestions/provenance source text are redacted, and LLM reasoning is omitted before JSONL write; local output cleanup owns stale file removal"
    }
  ]
}
