# Auto detect text files and perform LF normalization
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf

# Keep source and generated web assets LF in the working tree on Windows so
# lint and diff checks do not emit autocrlf churn warnings.
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.in text eol=lf
uv.lock text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.sh text eol=lf
MANIFEST.in text eol=lf

# Supplemental license bytes are pinned to immutable upstream digests. Keep
# Git from rewriting their authoritative byte representation on checkout.
crates/amw-engine/legal/cargo-supplemental/* -text
crates/amw-engine/legal/converter-supplemental/* -text

# Store public Windows launchers as authoritative CRLF blobs. The public
# provenance digest binds Git bytes, so checkout-time EOL rewriting is unsafe.
/start.bat -text
/python.cmd -text
/crates/amw-engine/vendor/llama.cpp/examples/sycl/*.bat -text
/crates/amw-engine/vendor/llama.cpp/scripts/install-oneapi.bat -text
