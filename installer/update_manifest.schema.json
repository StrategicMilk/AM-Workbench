{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/update_manifest.schema.json",
  "title": "Workbench Update Manifest",
  "type": "object",
  "required": ["schema_version", "version", "channel", "release_notes", "public_export", "artifacts", "integrity", "published_at_utc"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "version": {"type": "string", "minLength": 1},
    "channel": {"enum": ["stable", "beta"]},
    "release_notes": {"type": "string", "minLength": 1},
    "public_export": {
      "type": "object",
      "required": ["export_ref", "source_commit", "generated_at_utc"],
      "properties": {
        "export_ref": {"type": "string", "minLength": 1},
        "source_commit": {"type": "string", "minLength": 1},
        "generated_at_utc": {"type": "string", "minLength": 1}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["platform", "url", "digest", "size_bytes"],
        "properties": {
          "platform": {"type": "string", "minLength": 1},
          "url": {"type": "string", "minLength": 1},
          "digest": {"pattern": "^sha256:[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "local_path": {"type": "string"}
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": ["checksum_algorithm", "require_signature"],
      "properties": {
        "checksum_algorithm": {"const": "sha256"},
        "require_signature": {"type": "boolean"},
        "signature_evidence": {"type": "string"}
      }
    },
    "published_at_utc": {"type": "string", "minLength": 1},
    "rollback_from_version": {"type": "string"}
  }
}
