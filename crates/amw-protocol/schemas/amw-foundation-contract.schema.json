{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/amw-foundation-contract.schema.json",
  "title": "AMW Foundation Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "schema_version", "crates", "schemas"],
  "properties": {
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "amw-foundation-contract.v1"
    },
    "crates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
