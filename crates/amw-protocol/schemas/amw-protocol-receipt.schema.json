{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/amw-protocol-receipt.schema.json",
  "title": "AMW Protocol Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "provenance"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "failed_closed"]
    },
    "provenance": {
      "type": "string",
      "minLength": 1
    }
  }
}
