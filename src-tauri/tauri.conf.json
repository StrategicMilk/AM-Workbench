{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AM Workbench",
  "version": "0.6.0",
  "identifier": "local.vetinari.am-workbench",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui/svelte run dev",
    "beforeBuildCommand": "npm --prefix ../ui/svelte run build",
    "frontendDist": "../ui/static/svelte",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "AM Workbench",
        "label": "main",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; require-trusted-types-for 'script'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
