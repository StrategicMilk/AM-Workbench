{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_readiness.schema.json",
  "title": "Workbench Readiness Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "readiness_kind",
    "mode",
    "reasons",
    "recommended_actions",
    "feature_gates",
    "signals",
    "evidence_refs"
  ],
  "properties": {
    "readiness_kind": {
      "const": "operator_readiness"
    },
    "mode": {
      "enum": ["full", "minimal", "restricted", "blocked"]
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "feature_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_control",
        "launcher_first_run_setup",
        "automation_admission",
        "provider_use",
        "capability_pack_use",
        "connector_use",
        "run_kernel_operations"
      ],
      "properties": {
        "mission_control": { "$ref": "#/$defs/feature_gate_decision" },
        "launcher_first_run_setup": { "$ref": "#/$defs/feature_gate_decision" },
        "automation_admission": { "$ref": "#/$defs/feature_gate_decision" },
        "provider_use": { "$ref": "#/$defs/feature_gate_decision" },
        "capability_pack_use": { "$ref": "#/$defs/feature_gate_decision" },
        "connector_use": { "$ref": "#/$defs/feature_gate_decision" },
        "run_kernel_operations": { "$ref": "#/$defs/feature_gate_decision" }
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/signal" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "admission_preview": {
      "$ref": "#/$defs/admission_result"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "enum": ["minimal", "restricted", "blocked"] } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "reasons": { "minItems": 1 },
          "recommended_actions": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "feature_gate_decision": {
      "enum": ["open", "confirmation_required", "restricted", "blocked"]
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "status", "summary", "critical", "evidence_refs"],
      "properties": {
        "kind": {
          "enum": [
            "setup",
            "identity",
            "config",
            "provider",
            "capability_pack",
            "policy",
            "scheduler",
            "memory",
            "connector",
            "tool_pin",
            "run_kernel",
            "verified_history",
            "probe"
          ]
        },
        "status": {
          "enum": [
            "passing",
            "verified",
            "degraded",
            "confirmation_required",
            "stale",
            "unknown",
            "missing",
            "unreadable",
            "corrupt",
            "incompatible",
            "failing"
          ]
        },
        "summary": { "type": "string", "minLength": 1 },
        "critical": { "type": "boolean" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_ref" }
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "kind"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" }
      }
    },
    "admission_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "allowed", "feature", "gate", "mode", "reasons", "required_actions"],
      "properties": {
        "decision": { "enum": ["allow", "require_confirmation", "restrict", "block"] },
        "allowed": { "type": "boolean" },
        "feature": {
          "enum": [
            "mission_control",
            "launcher_first_run_setup",
            "automation_admission",
            "provider_use",
            "capability_pack_use",
            "connector_use",
            "run_kernel_operations"
          ]
        },
        "gate": { "$ref": "#/$defs/feature_gate_decision" },
        "mode": { "enum": ["full", "minimal", "restricted", "blocked"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
