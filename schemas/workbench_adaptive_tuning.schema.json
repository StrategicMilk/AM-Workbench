{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_adaptive_tuning.schema.json",
  "title": "Workbench Adaptive Tuning",
  "type": "object",
  "required": ["schema_version", "project_id", "hypotheses", "controls"],
  "properties": {
    "schema_version": { "const": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "hypotheses": {
      "type": "array",
      "items": { "$ref": "#/$defs/hypothesis" }
    },
    "controls": {
      "type": "array",
      "items": { "$ref": "#/$defs/control" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "scope": {
      "type": "object",
      "required": ["project_id", "surface"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "surface": { "type": "string", "minLength": 1 },
        "workflow_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "kind",
        "summary",
        "scope",
        "observed_at_utc",
        "confidence",
        "evidence_refs",
        "provenance_ref",
        "status",
        "blockers"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/scope" },
        "observed_at_utc": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "provenance_ref": { "type": "string", "minLength": 1 },
        "status": { "enum": ["accepted", "rejected"] },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "target": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "hypothesis": {
      "type": "object",
      "required": [
        "hypothesis_id",
        "title",
        "status",
        "scope",
        "evidence",
        "confidence",
        "created_at_utc",
        "last_observed_at_utc",
        "decay_after_days",
        "controls"
      ],
      "properties": {
        "hypothesis_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pending", "active", "blocked", "rejected", "forgotten", "decayed", "revoked"] },
        "scope": { "$ref": "#/$defs/scope" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "created_at_utc": { "type": "string" },
        "last_observed_at_utc": { "type": "string" },
        "decay_after_days": { "type": "integer", "minimum": 1 },
        "controls": {
          "type": "array",
          "contains": { "const": "allow" },
          "items": { "enum": ["allow", "reject", "edit", "forget", "revoke", "preview", "rollback", "policy_override"] }
        },
        "proposal": { "type": ["object", "null"] },
        "fail_closed_reasons": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "control": {
      "type": "object",
      "required": ["hypothesis_id", "action", "decided_at_utc", "actor_ref"],
      "properties": {
        "hypothesis_id": { "type": "string", "minLength": 1 },
        "action": { "enum": ["allow", "reject", "edit", "forget", "revoke", "preview", "rollback", "policy_override"] },
        "decided_at_utc": { "type": "string" },
        "actor_ref": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
