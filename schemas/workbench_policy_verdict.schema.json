{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_policy_verdict.schema.json",
  "title": "WorkbenchPolicyVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict_id",
    "value",
    "mode",
    "risk_domain",
    "reason_code",
    "action_id",
    "actor_id",
    "run_id",
    "evidence_links",
    "replay_metadata",
    "policy_version",
    "evaluated_at_utc",
    "summary",
    "details"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "verdict_id": {"type": "string", "minLength": 1},
    "value": {"enum": ["allow", "warn", "block", "escalate"]},
    "mode": {"enum": ["observe", "warn", "strict"]},
    "risk_domain": {
      "enum": [
        "shell",
        "file_system",
        "network",
        "tool_invocation",
        "memory_scope",
        "token_budget",
        "cost_budget",
        "loop_amplification",
        "side_effect",
        "permission",
        "remote_control",
        "approval"
      ]
    },
    "reason_code": {
      "enum": [
        "allowed",
        "missing_evidence",
        "missing_actor_id",
        "missing_run_id",
        "missing_authority",
        "unknown_action",
        "unknown_risk_domain",
        "unreadable_policy",
        "policy_mode_strict_blocked",
        "policy_mode_warn_warned",
        "escalated_to_user",
        "remote_intent_unverified",
        "replay_metadata_missing",
        "schema_version_mismatch"
      ]
    },
    "action_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "kind", "ref", "summary"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["run", "trace", "lease", "receipt", "proposal", "asset", "external"]},
          "ref": {"type": "string", "minLength": 1},
          "summary": {"type": "string"}
        }
      }
    },
    "replay_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "policy_version", "mode", "captured_at_utc"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "policy_version": {"type": "string", "minLength": 1},
        "mode": {"enum": ["observe", "warn", "strict"]},
        "captured_at_utc": {"type": "string", "minLength": 1},
        "policy_path_canonical": {"type": "string"},
        "correlation_id": {"type": "string"}
      }
    },
    "policy_version": {"type": "string", "minLength": 1},
    "evaluated_at_utc": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "details": {"type": "object"}
  }
}
