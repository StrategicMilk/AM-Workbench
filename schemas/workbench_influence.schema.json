{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_influence.schema.json",
  "title": "AM Workbench Influence Link",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "influence_id",
    "source_event_id",
    "target_event_id",
    "kind",
    "authority_level",
    "evidence_refs",
    "provenance_refs",
    "confidence",
    "rationale",
    "created_at_utc",
    "reversible"
  ],
  "properties": {
    "influence_id": {"type": "string", "minLength": 1},
    "source_event_id": {"type": "string", "minLength": 1},
    "target_event_id": {"type": "string", "minLength": 1},
    "kind": {
      "type": "string",
      "enum": [
        "derived_from",
        "evidence_for",
        "caused_by",
        "approved_by",
        "blocked_by",
        "supersedes",
        "depends_on"
      ]
    },
    "authority_level": {
      "type": "string",
      "enum": ["observed", "suggested", "proposed", "approved", "executed", "promoted"]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "confidence": {"type": "number", "exclusiveMinimum": 0.0, "maximum": 1.0},
    "rationale": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string", "minLength": 1},
    "reversible": {"type": "boolean"}
  }
}
