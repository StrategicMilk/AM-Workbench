{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-workbench.local/schemas/ide_extension.schema.json",
  "title": "AM Workbench IDE Extension Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "extension_id",
    "schema_version",
    "signature",
    "permissions",
    "retention_days",
    "privacy",
    "receipt_path"
  ],
  "properties": {
    "extension_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "ide-extension.v1"
    },
    "signature": {
      "type": "string",
      "pattern": "^signed:[a-zA-Z0-9_-]{1,64}$"
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(tool|resource):[A-Za-z0-9_:/-]+$|^fs_read:(?!/|[A-Za-z]:|.*\\.\\.)(?!.*\\\\)[A-Za-z0-9_./-]+$"
      }
    },
    "retention_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redaction", "deletion"],
      "properties": {
        "redaction": {
          "const": "secret-bearing-fields"
        },
        "deletion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "receipt_path": {
      "type": "string",
      "pattern": "^receipts/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    }
  }
}
