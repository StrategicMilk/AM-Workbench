{
  "$id": "https://vetinari.local/schemas/workbench_memory_lineage.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AM Workbench memory lineage usage telemetry",
  "description": "Fail-closed memory lineage and usage telemetry payload for Workbench memory assets.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "asset_id",
        "revision"
      ]
    },
    "source_run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_call_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_asset_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "eval_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_state": {
      "const": "verified"
    },
    "prompt_injection_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "required": [
        "source",
        "reason"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memory_tier": {
          "const": "memory"
        },
        "memory_rank": {
          "const": 80
        },
        "stronger_than_memory": {
          "type": "array",
          "contains": {
            "const": "code"
          },
          "items": {
            "enum": [
              "code",
              "test",
              "adr",
              "runtime_evidence"
            ]
          }
        }
      },
      "required": [
        "memory_tier",
        "memory_rank",
        "stronger_than_memory"
      ]
    },
    "usage_telemetry": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/usage"
      }
    }
  },
  "required": [
    "schema_version",
    "memory_id",
    "asset_ref",
    "source_run_id",
    "trace_id",
    "tool_call_ids",
    "evidence_asset_ids",
    "eval_ids",
    "receipt_ids",
    "policy_ref",
    "validation_state",
    "prompt_injection_ids",
    "created_at_utc",
    "provenance",
    "authority",
    "usage_telemetry"
  ],
  "$defs": {
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "usage_id": {
          "type": "string",
          "minLength": 1
        },
        "memory_id": {
          "type": "string",
          "minLength": 1
        },
        "recalled_for_run_id": {
          "type": "string",
          "minLength": 1
        },
        "recalled_at_utc": {
          "type": "string",
          "minLength": 1
        },
        "recall_reason": {
          "type": "string",
          "minLength": 1
        },
        "used": {
          "type": "boolean"
        },
        "outcome": {
          "enum": [
            "helped",
            "harmed",
            "neutral",
            "unknown"
          ]
        },
        "helped_harmed_classification": {
          "type": "string",
          "minLength": 1
        },
        "authority_tier": {
          "const": "memory"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "usage_id",
        "memory_id",
        "recalled_for_run_id",
        "recalled_at_utc",
        "recall_reason",
        "used",
        "outcome",
        "helped_harmed_classification",
        "authority_tier",
        "evidence_refs",
        "notes"
      ]
    }
  }
}
