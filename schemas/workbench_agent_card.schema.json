{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_agent_card.schema.json",
  "title": "Workbench Agent Template Gallery",
  "type": "object",
  "required": ["schema_version", "templates"],
  "properties": {
    "schema_version": { "const": 1 },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/template" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "stableId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "template": {
      "type": "object",
      "required": [
        "template_id",
        "name",
        "role",
        "purpose",
        "allowed_tools",
        "permissions",
        "memory_scope",
        "model_policy",
        "cost_profile",
        "eval_history",
        "failure_history",
        "allowed_data_classes",
        "compatibility_requirements",
        "capability_pack_ids",
        "mode_template_ids",
        "sandbox_profile",
        "trust_badges",
        "risk_posture",
        "revision",
        "provenance"
      ],
      "properties": {
        "template_id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/stableId" },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "allowed_tools": { "$ref": "#/$defs/nonEmptyStringArray" },
        "permissions": { "$ref": "#/$defs/nonEmptyStringArray" },
        "memory_scope": { "$ref": "#/$defs/nonEmptyStringArray" },
        "model_policy": {
          "type": "object",
          "required": ["allowed_providers", "default_tier", "fallback_tier"],
          "properties": {
            "allowed_providers": { "$ref": "#/$defs/nonEmptyStringArray" },
            "default_tier": { "$ref": "#/$defs/nonEmptyString" },
            "fallback_tier": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        "cost_profile": {
          "type": "object",
          "required": ["budget_class", "max_tokens_per_run", "requires_budget_ack"],
          "properties": {
            "budget_class": { "$ref": "#/$defs/nonEmptyString" },
            "max_tokens_per_run": { "type": "integer", "minimum": 1 },
            "requires_budget_ack": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "eval_history": { "$ref": "#/$defs/nonEmptyStringArray" },
        "failure_history": { "$ref": "#/$defs/nonEmptyStringArray" },
        "allowed_data_classes": { "$ref": "#/$defs/nonEmptyStringArray" },
        "compatibility_requirements": { "$ref": "#/$defs/nonEmptyStringArray" },
        "capability_pack_ids": { "$ref": "#/$defs/nonEmptyStringArray" },
        "mode_template_ids": { "$ref": "#/$defs/nonEmptyStringArray" },
        "sandbox_profile": { "$ref": "#/$defs/nonEmptyString" },
        "trust_badges": {
          "type": "object",
          "required": [
            "local_only",
            "networked",
            "secret_accessing",
            "model_training",
            "writes_files",
            "deploys_code",
            "incident_response_capable"
          ],
          "properties": {
            "local_only": { "type": "boolean" },
            "networked": { "type": "boolean" },
            "secret_accessing": { "type": "boolean" },
            "model_training": { "type": "boolean" },
            "writes_files": { "type": "boolean" },
            "deploys_code": { "type": "boolean" },
            "incident_response_capable": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "risk_posture": {
          "type": "object",
          "required": ["risk_level", "review_required", "approval_required", "isolation_profile"],
          "properties": {
            "risk_level": { "enum": ["low", "medium", "high"] },
            "review_required": { "type": "boolean" },
            "approval_required": { "type": "boolean" },
            "isolation_profile": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        "revision": { "$ref": "#/$defs/nonEmptyString" },
        "provenance": {
          "type": "object",
          "required": ["source", "decision_ref"],
          "properties": {
            "source": { "$ref": "#/$defs/nonEmptyString" },
            "decision_ref": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
