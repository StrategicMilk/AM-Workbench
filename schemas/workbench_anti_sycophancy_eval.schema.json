{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_anti_sycophancy_eval.schema.json",
  "title": "Workbench Anti-Sycophancy Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/eval_case"
      }
    },
    "gate_decision": {
      "$ref": "#/$defs/gate_decision"
    }
  },
  "$defs": {
    "scenario_kind": {
      "type": "string",
      "enum": [
        "false_assumption",
        "leading_question",
        "unsafe_shortcut",
        "overconfident_request",
        "evidence_challenge"
      ]
    },
    "target_artifact_kind": {
      "type": "string",
      "enum": ["prompt", "memory", "route", "model", "adapter", "specialist_variant"]
    },
    "ref_string": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agreement",
        "disagreement",
        "evidence_request",
        "correction_quality",
        "safety_enforcement",
        "factual_standard_preservation"
      ],
      "properties": {
        "agreement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "disagreement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_request": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "correction_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "safety_enforcement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "factual_standard_preservation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "eval_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "scenario_kind",
        "target_artifact_kind",
        "user_prompt",
        "false_assumption_text",
        "evidence_challenge_text",
        "expected_challenge_behavior",
        "trace_ref",
        "route_decision_ref",
        "policy_explanation_ref",
        "governance_ref",
        "provenance_refs",
        "minimum_passing_metrics"
      ],
      "properties": {
        "case_id": {
          "$ref": "#/$defs/ref_string"
        },
        "scenario_kind": {
          "$ref": "#/$defs/scenario_kind"
        },
        "target_artifact_kind": {
          "$ref": "#/$defs/target_artifact_kind"
        },
        "user_prompt": {
          "$ref": "#/$defs/ref_string"
        },
        "false_assumption_text": {
          "$ref": "#/$defs/ref_string"
        },
        "evidence_challenge_text": {
          "$ref": "#/$defs/ref_string"
        },
        "expected_challenge_behavior": {
          "$ref": "#/$defs/ref_string"
        },
        "trace_ref": {
          "$ref": "#/$defs/ref_string"
        },
        "route_decision_ref": {
          "$ref": "#/$defs/ref_string"
        },
        "policy_explanation_ref": {
          "$ref": "#/$defs/ref_string"
        },
        "governance_ref": {
          "$ref": "#/$defs/ref_string"
        },
        "provenance_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ref_string"
          }
        },
        "minimum_passing_metrics": {
          "$ref": "#/$defs/metrics"
        }
      }
    },
    "gate_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved", "blockers", "evidence"],
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ref_string"
          }
        },
        "evidence": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      }
    }
  }
}
