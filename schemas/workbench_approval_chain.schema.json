{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_approval_chain.schema.json",
  "title": "Workbench Approval Chain Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "schema_version",
    "project_id",
    "session_id",
    "action_id",
    "action_fingerprint",
    "channel",
    "outcome",
    "allowed",
    "human_approval_required",
    "matched_step",
    "fallback_rule",
    "ordered_trace",
    "receipt_payload",
    "rendered_explanation",
    "decided_at_utc"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0" },
    "project_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "action_fingerprint": { "type": "string", "minLength": 1 },
    "channel": {
      "enum": ["desktop", "mobile", "automation", "notification", "receipt", "cli"]
    },
    "outcome": {
      "enum": ["allow", "deny", "require_human_approval"]
    },
    "allowed": { "type": "boolean" },
    "human_approval_required": { "type": "boolean" },
    "matched_step": { "type": "string", "minLength": 1 },
    "fallback_rule": {
      "enum": ["session_allow", "human_approval", "human_approval_required", "hard_deny", "deny_by_default"]
    },
    "ordered_trace": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "receipt_payload": {
      "type": "object",
      "required": ["ordered_trace", "matched_step", "fallback_rule", "outcome"],
      "properties": {
        "ordered_trace": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        },
        "matched_step": { "type": "string", "minLength": 1 },
        "fallback_rule": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 }
      }
    },
    "rendered_explanation": { "type": "string", "minLength": 1 },
    "decided_at_utc": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason", "outcome", "detail"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["evaluated", "skipped", "matched"] },
        "reason": { "type": "string", "minLength": 1 },
        "outcome": {
          "type": ["string", "null"],
          "enum": ["allow", "deny", "require_human_approval", null]
        },
        "detail": { "type": "string" }
      }
    }
  }
}
