{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_agent_mailbox.schema.json",
  "title": "Workbench Agent Mailbox Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "health", "messages", "receipts"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "health": {"type": "string", "enum": ["ok", "degraded"]},
    "messages": {
      "type": "array",
      "items": {"$ref": "#/$defs/message"}
    },
    "receipts": {
      "type": "array",
      "items": {"$ref": "#/$defs/receipt"}
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["causal_message_ids", "prompt_refs", "tool_call_refs", "memory_refs", "receipt_refs"],
      "properties": {
        "causal_message_ids": {"$ref": "#/$defs/string_array"},
        "prompt_refs": {"$ref": "#/$defs/string_array"},
        "tool_call_refs": {"$ref": "#/$defs/string_array"},
        "memory_refs": {"$ref": "#/$defs/string_array"},
        "receipt_refs": {"$ref": "#/$defs/string_array"}
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "owner", "granted_at_utc", "expires_at_utc"],
      "properties": {
        "lease_id": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "granted_at_utc": {"type": "string", "minLength": 1},
        "expires_at_utc": {"type": "string", "minLength": 1}
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_id",
        "sender",
        "recipients",
        "kind",
        "subject",
        "content",
        "created_at_utc",
        "expires_at_utc",
        "max_attempts",
        "state",
        "attempts",
        "lease",
        "references",
        "provenance",
        "safety_ref",
        "confidence",
        "last_error",
        "dead_letter_reason"
      ],
      "properties": {
        "message_id": {"type": "string", "minLength": 1},
        "sender": {"type": "string", "minLength": 1},
        "recipients": {"$ref": "#/$defs/string_array"},
        "kind": {
          "type": "string",
          "enum": [
            "help_request",
            "delegation",
            "challenge",
            "observation",
            "queue_signal",
            "automation_signal",
            "memory_signal"
          ]
        },
        "subject": {"type": "string", "minLength": 1},
        "content": {"type": "string", "minLength": 1},
        "created_at_utc": {"type": "string", "minLength": 1},
        "expires_at_utc": {"type": "string", "minLength": 1},
        "max_attempts": {"type": "integer", "minimum": 1},
        "state": {
          "type": "string",
          "enum": ["pending", "leased", "completed", "failed", "dead_letter", "blocked"]
        },
        "attempts": {"type": "integer", "minimum": 0},
        "lease": {"anyOf": [{"$ref": "#/$defs/lease"}, {"type": "null"}]},
        "references": {"$ref": "#/$defs/references"},
        "provenance": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1},
          "required": ["source"]
        },
        "safety_ref": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "last_error": {"type": "string"},
        "dead_letter_reason": {"type": "string"}
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "operation",
        "outcome",
        "emitted_at_utc",
        "message_id",
        "lease_id",
        "actor",
        "reasons",
        "missing_signals",
        "passed"
      ],
      "properties": {
        "receipt_id": {"type": "string", "minLength": 1},
        "operation": {"type": "string", "minLength": 1},
        "outcome": {
          "type": "string",
          "enum": [
            "accepted",
            "claimed",
            "completed",
            "retry_scheduled",
            "dead_lettered",
            "blocked",
            "degraded",
            "no_message"
          ]
        },
        "emitted_at_utc": {"type": "string", "minLength": 1},
        "message_id": {"type": "string"},
        "lease_id": {"type": "string"},
        "actor": {"type": "string"},
        "reasons": {"$ref": "#/$defs/string_array"},
        "missing_signals": {"$ref": "#/$defs/string_array"},
        "passed": {"type": "boolean"}
      }
    }
  }
}
