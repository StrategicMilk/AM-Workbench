{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_habit_health.schema.json",
  "title": "Workbench Habit Health Signal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "user_id",
    "signal_kind",
    "scope",
    "source_context",
    "consent_refs",
    "provenance_ref",
    "retention",
    "non_medical_boundary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "routine_id": { "type": "string" },
    "signal_kind": {
      "type": "string",
      "enum": [
        "routine",
        "check_in",
        "missed_cadence",
        "energy_focus",
        "agent_rhythm",
        "downstream_preview",
        "privacy_review"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "personal_wellness",
        "project_telemetry",
        "agent_run_telemetry",
        "sensitive_memory_context"
      ]
    },
    "source_context": { "type": "string", "minLength": 1 },
    "consent_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "provenance_ref": { "type": "string", "minLength": 1 },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["days", "delete_visible", "export_visible"],
      "properties": {
        "days": { "type": "integer", "minimum": 1 },
        "delete_visible": { "type": "boolean", "const": true },
        "export_visible": { "type": "boolean", "const": true }
      }
    },
    "non_medical_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["does_not_diagnose", "does_not_prescribe", "user_framed_context_only"],
      "properties": {
        "does_not_diagnose": { "type": "boolean", "const": true },
        "does_not_prescribe": { "type": "boolean", "const": true },
        "user_framed_context_only": { "type": "boolean", "const": true }
      }
    },
    "downstream_use": { "type": "string" },
    "downstream_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "payload": { "type": "object" }
  },
  "not": {
    "anyOf": [
      { "required": ["diagnosis"] },
      { "required": ["treatment"] },
      { "required": ["medication"] },
      { "required": ["clinical_recommendation"] }
    ]
  }
}
