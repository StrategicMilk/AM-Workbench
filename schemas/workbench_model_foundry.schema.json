{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_model_foundry.schema.json",
  "title": "Workbench Model Foundry Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["recipe", "job", "artifact"],
  "properties": {
    "recipe": { "$ref": "#/$defs/recipe" },
    "job": { "$ref": "#/$defs/job" },
    "artifact": { "$ref": "#/$defs/artifact" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "strategy": {
      "enum": [
        "scratch_pretraining",
        "tiny_utility_scratch",
        "continued_pretraining",
        "fine_tuning_adapter",
        "preference_tuning",
        "distillation",
        "route_eligibility"
      ]
    },
    "artifactKind": {
      "enum": [
        "base_model",
        "tiny_utility_model",
        "continued_pretrained_model",
        "adapter",
        "preference_adapter",
        "distilled_model",
        "route_eligibility_card"
      ]
    },
    "tokenizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokenizer_id", "kind", "vocab_size", "source_ref", "training_corpus_ref"],
      "properties": {
        "tokenizer_id": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "enum": ["bpe", "sentencepiece", "unigram", "existing"] },
        "vocab_size": { "type": "integer", "minimum": 1 },
        "source_ref": { "$ref": "#/$defs/nonEmptyString" },
        "training_corpus_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "scratchSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["architecture", "parameter_count", "context_window", "tokenizer", "initialization_ref"],
      "properties": {
        "architecture": { "$ref": "#/$defs/nonEmptyString" },
        "parameter_count": { "type": "integer", "minimum": 1 },
        "context_window": { "type": "integer", "minimum": 1 },
        "tokenizer": { "$ref": "#/$defs/tokenizer" },
        "initialization_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "datasetRevision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_revision_id", "source_card_id", "consent_ref", "license_ref", "pii_taint", "lineage_ref"],
      "properties": {
        "dataset_revision_id": { "$ref": "#/$defs/nonEmptyString" },
        "source_card_id": { "$ref": "#/$defs/nonEmptyString" },
        "consent_ref": { "$ref": "#/$defs/nonEmptyString" },
        "license_ref": { "$ref": "#/$defs/nonEmptyString" },
        "pii_taint": { "type": "boolean" },
        "lineage_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "sourceCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_card_id", "policy_ref", "provenance_ref", "license_classification"],
      "properties": {
        "source_card_id": { "$ref": "#/$defs/nonEmptyString" },
        "policy_ref": { "$ref": "#/$defs/nonEmptyString" },
        "provenance_ref": { "$ref": "#/$defs/nonEmptyString" },
        "license_classification": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "evalGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eval_id", "metric_name", "value", "threshold", "passed", "evidence_ref"],
      "properties": {
        "eval_id": { "$ref": "#/$defs/nonEmptyString" },
        "metric_name": { "$ref": "#/$defs/nonEmptyString" },
        "value": { "type": "number" },
        "threshold": { "type": "number" },
        "passed": { "type": "boolean" },
        "evidence_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimate_id",
        "parameters",
        "training_tokens",
        "hardware",
        "storage_gb",
        "checkpoint_cadence_steps",
        "estimated_wall_clock_hours",
        "stop_conditions",
        "blockers"
      ],
      "properties": {
        "estimate_id": { "$ref": "#/$defs/nonEmptyString" },
        "parameters": { "type": "integer", "minimum": 1 },
        "training_tokens": { "type": "integer", "minimum": 1 },
        "hardware": { "$ref": "#/$defs/nonEmptyString" },
        "storage_gb": { "type": "number", "minimum": 0 },
        "checkpoint_cadence_steps": { "type": "integer", "minimum": 1 },
        "estimated_wall_clock_hours": { "type": "number", "minimum": 0 },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipe_id",
        "strategy",
        "output_kind",
        "base_model_ref",
        "dataset_revisions",
        "source_cards",
        "eval_gates",
        "receipt_refs",
        "rollback_target_ref",
        "route_eligible",
        "budget_ref",
        "scratch_spec",
        "base_model_parameter_count",
        "distillation_teacher_ref"
      ],
      "properties": {
        "recipe_id": { "$ref": "#/$defs/nonEmptyString" },
        "strategy": { "$ref": "#/$defs/strategy" },
        "output_kind": { "$ref": "#/$defs/artifactKind" },
        "base_model_ref": { "type": "string" },
        "dataset_revisions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/datasetRevision" }
        },
        "source_cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceCard" }
        },
        "eval_gates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evalGate" }
        },
        "receipt_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "rollback_target_ref": { "$ref": "#/$defs/nonEmptyString" },
        "route_eligible": { "type": "boolean" },
        "budget_ref": { "$ref": "#/$defs/nonEmptyString" },
        "scratch_spec": {
          "anyOf": [{ "$ref": "#/$defs/scratchSpec" }, { "type": "null" }]
        },
        "base_model_parameter_count": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "distillation_teacher_ref": { "type": "string" }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "recipe_id", "strategy", "status", "estimate", "blockers", "receipt_refs", "created_at_utc"],
      "properties": {
        "job_id": { "$ref": "#/$defs/nonEmptyString" },
        "recipe_id": { "$ref": "#/$defs/nonEmptyString" },
        "strategy": { "$ref": "#/$defs/strategy" },
        "status": { "enum": ["dry_run", "blocked", "ready", "running", "completed"] },
        "estimate": { "$ref": "#/$defs/estimate" },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "receipt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "created_at_utc": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "kind",
        "recipe_id",
        "job_id",
        "artifact_ref",
        "dataset_revision_ids",
        "source_card_ids",
        "eval_gates",
        "receipt_refs",
        "rollback_target_ref",
        "route_eligible"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "$ref": "#/$defs/artifactKind" },
        "recipe_id": { "$ref": "#/$defs/nonEmptyString" },
        "job_id": { "$ref": "#/$defs/nonEmptyString" },
        "artifact_ref": { "$ref": "#/$defs/nonEmptyString" },
        "dataset_revision_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "source_card_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "eval_gates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evalGate" }
        },
        "receipt_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "rollback_target_ref": { "$ref": "#/$defs/nonEmptyString" },
        "route_eligible": { "type": "boolean" }
      }
    }
  }
}
