{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_card.schema.json",
  "title": "Workbench Collaboration Card Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "card_id",
    "kind",
    "title",
    "project_id",
    "subject_id",
    "revision",
    "provenance",
    "evidence_refs",
    "governance_refs",
    "sections",
    "risk_posture",
    "degraded",
    "redactions_applied",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "card_id": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": ["model_card", "dataset_card", "data_card", "prompt_card", "system_card"]
    },
    "kind_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "subject_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "string", "minLength": 1 },
          { "type": "string", "minLength": 1 }
        ],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "governance_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "string", "minLength": 1 },
          { "type": "string", "minLength": 1 }
        ],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      }
    },
    "collaboration": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "risk_posture": { "type": "string", "minLength": 1 },
    "risk_posture_label": { "type": "string", "minLength": 1 },
    "degraded": { "type": "boolean" },
    "redactions_applied": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
