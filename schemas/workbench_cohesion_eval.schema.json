{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_cohesion_eval.schema.json",
  "title": "Workbench Persona Cohesion Eval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": { "const": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/CohesionEvalCase" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "dimension": {
      "enum": [
        "project_preference",
        "anti_sycophancy",
        "uncertainty_escalation",
        "feedback_as_data",
        "cross_surface_cohesion"
      ]
    },
    "surface": {
      "enum": ["desktop", "mobile", "automation", "resumed_session", "cli", "imported_workflow"]
    },
    "feedbackKind": { "enum": ["none", "positive", "negative", "correction"] },
    "refArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "DependencyRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_eval_refs",
        "memory_governance_refs",
        "personalization_governance_refs",
        "project_preference_refs",
        "anti_sycophancy_gate_ref"
      ],
      "properties": {
        "trace_eval_refs": { "$ref": "#/$defs/refArray" },
        "memory_governance_refs": { "$ref": "#/$defs/refArray" },
        "personalization_governance_refs": { "$ref": "#/$defs/refArray" },
        "project_preference_refs": { "$ref": "#/$defs/refArray" },
        "anti_sycophancy_gate_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "CohesionEvalCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "dimension",
        "surface",
        "prompt_ref",
        "expected_behavior_ref",
        "dependency_refs",
        "feedback_kind",
        "feedback_refs",
        "minimum_score",
        "eval_label_only"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/nonEmptyString" },
        "dimension": { "$ref": "#/$defs/dimension" },
        "surface": { "$ref": "#/$defs/surface" },
        "prompt_ref": { "$ref": "#/$defs/nonEmptyString" },
        "expected_behavior_ref": { "$ref": "#/$defs/nonEmptyString" },
        "dependency_refs": { "$ref": "#/$defs/DependencyRefs" },
        "feedback_kind": { "$ref": "#/$defs/feedbackKind" },
        "feedback_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "minimum_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "eval_label_only": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": { "feedback_kind": { "enum": ["positive", "negative", "correction"] } },
            "required": ["feedback_kind"]
          },
          "then": { "properties": { "feedback_refs": { "$ref": "#/$defs/refArray" } } }
        }
      ]
    },
    "CohesionObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "dimension",
        "surface",
        "answer_ref",
        "score",
        "dependency_refs",
        "anti_sycophancy_decision",
        "uncertainty_escalation_refs",
        "feedback_evidence_refs",
        "cross_surface_consistency_refs",
        "truthfulness_refs",
        "safety_refs"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/nonEmptyString" },
        "dimension": { "$ref": "#/$defs/dimension" },
        "surface": { "$ref": "#/$defs/surface" },
        "answer_ref": { "$ref": "#/$defs/nonEmptyString" },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "dependency_refs": { "$ref": "#/$defs/DependencyRefs" },
        "anti_sycophancy_decision": {
          "type": "object",
          "additionalProperties": true,
          "required": ["approved", "blockers", "evidence"],
          "properties": {
            "approved": { "type": "boolean" },
            "blockers": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } },
            "evidence": { "type": "object" }
          }
        },
        "uncertainty_escalation_refs": { "$ref": "#/$defs/refArray" },
        "feedback_evidence_refs": { "$ref": "#/$defs/refArray" },
        "cross_surface_consistency_refs": { "$ref": "#/$defs/refArray" },
        "truthfulness_refs": { "$ref": "#/$defs/refArray" },
        "safety_refs": { "$ref": "#/$defs/refArray" }
      }
    },
    "CohesionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "run_id", "status", "approved", "blockers", "dimension_scores", "evidence"],
      "properties": {
        "schema_version": { "const": 1 },
        "run_id": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["approved", "blocked", "loader_error"] },
        "approved": { "type": "boolean" },
        "blockers": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } },
        "dimension_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "dimension",
              "surface",
              "baseline_score",
              "candidate_score",
              "minimum_score",
              "passed",
              "blockers"
            ],
            "properties": {
              "case_id": { "$ref": "#/$defs/nonEmptyString" },
              "dimension": { "$ref": "#/$defs/dimension" },
              "surface": { "$ref": "#/$defs/surface" },
              "baseline_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "candidate_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "minimum_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "passed": { "type": "boolean" },
              "blockers": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } }
            }
          }
        },
        "evidence": { "type": "object" }
      }
    },
    "ImprovementProposalRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "target",
        "lifecycle",
        "source_signals",
        "baseline_evidence",
        "candidate_evidence",
        "regression_checks",
        "negative_results",
        "impacted_assets",
        "rollback_target_ref",
        "expires_at_utc",
        "post_promotion_monitoring_refs",
        "dependency_refs"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "candidate_id": { "$ref": "#/$defs/nonEmptyString" },
        "target": { "const": "eval_case" },
        "lifecycle": { "const": "shadow" },
        "source_signals": { "type": "array", "minItems": 1 },
        "baseline_evidence": { "type": "array", "minItems": 1 },
        "candidate_evidence": { "type": "array", "minItems": 1 },
        "regression_checks": { "type": "array", "minItems": 1 },
        "negative_results": { "type": "array", "minItems": 1 },
        "impacted_assets": { "$ref": "#/$defs/refArray" },
        "risk": { "$ref": "#/$defs/nonEmptyString" },
        "rollback_target_ref": { "$ref": "#/$defs/nonEmptyString" },
        "expires_at_utc": { "$ref": "#/$defs/nonEmptyString" },
        "post_promotion_monitoring_refs": { "$ref": "#/$defs/refArray" },
        "dependency_refs": { "type": "object" }
      }
    }
  }
}
