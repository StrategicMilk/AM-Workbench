{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vetinari.local/schemas/workbench_agent_run_harness.schema.json",
  "title": "Workbench Agent Run Harness Request",
  "type": "object",
  "required": [
    "run_id",
    "template_id",
    "sandbox",
    "requested_tools",
    "workspace_path",
    "input_payload_ref",
    "expected_output_ref",
    "receipt_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "template_id": { "type": "string", "minLength": 1 },
    "workspace_path": { "type": "string", "minLength": 1 },
    "input_payload_ref": { "type": "string", "minLength": 1 },
    "expected_output_ref": { "type": "string", "minLength": 1 },
    "requested_tools": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "receipt_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sandbox": {
      "type": "object",
      "required": [
        "sandbox_id",
        "workspace_ref",
        "allowed_workspace_prefix",
        "tool_permissions",
        "file_exposure",
        "network_exposure",
        "process_exposure",
        "model_policy_ref",
        "memory_profile_ref",
        "input_schema_ref",
        "output_schema_ref",
        "receipt_requirements",
        "cancellation_behavior",
        "replay_boundary_ref",
        "authority_ref",
        "provenance_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "sandbox_id": { "type": "string", "minLength": 1 },
        "workspace_ref": { "type": "string", "minLength": 1 },
        "allowed_workspace_prefix": { "type": "string", "minLength": 1 },
        "tool_permissions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "file_exposure": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "network_exposure": { "type": "string", "enum": ["denied", "allowlisted"] },
        "process_exposure": { "type": "string", "enum": ["none", "limited"] },
        "model_policy_ref": { "type": "string", "minLength": 1 },
        "memory_profile_ref": { "type": "string", "minLength": 1 },
        "input_schema_ref": { "type": "string", "minLength": 1 },
        "output_schema_ref": { "type": "string", "minLength": 1 },
        "receipt_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cancellation_behavior": { "type": "string", "minLength": 1 },
        "replay_boundary_ref": { "type": "string", "minLength": 1 },
        "authority_ref": { "type": "string", "minLength": 1 },
        "provenance_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
